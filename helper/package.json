{
  "name": "smc-helper",
  "version": "0.3.0",
  "private": true,
  "description": "Silent Meeting Copilot — desktop audio capture helper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "london.pacific.smc-helper",
    "productName": "SMC Helper",
    "artifactName": "${productName}-${version}.${ext}",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "artifactName": "SMC-Helper-Setup.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "artifactName": "SMC-Helper-mac.${ext}"
    },
    "dmg": {
      "artifactName": "SMC-Helper.${ext}"
    }
  }
}
