# Silent Meeting Copilot - environment configuration.
# Copy to .env and fill in. .env is gitignored and must never be committed.

# ---- Local transcription (faster-whisper) ----
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Default audio input device index (blank = system default).
AUDIO_INPUT_DEVICE=

# ---- LLM provider (Checkpoint 5, not used by the spike) ----
# One provider only in v1. Set LLM_PROVIDER and the matching key.
LLM_PROVIDER=openai
OPENAI_API_KEY=
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=